{
    "name": "multifrost/php",
    "description": "Multifrost v5 PHP binding — blocking synchronous caller and service peers over WebSocket",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "rybakit/msgpack": "^0.10",
        "phrity/websocket": "^3.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "classmap": ["src/"],
        "files": ["src/functions.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Multifrost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src tests --level=6"
    }
}
