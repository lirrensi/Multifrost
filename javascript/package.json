{
    "name": "multifrost",
    "version": "5.0.0",
    "description": "Router-based v5 RPC library for Python, Node.js, Go, and Rust",
    "license": "MIT",
    "author": "lirrensi",
    "type": "module",
    "main": "index.ts",
    "scripts": {
        "test": "npm run test:unit && npm run test:interop",
        "test:unit": "node ./node_modules/tsx/dist/cli.mjs tests/v5_unit.test.ts",
        "test:interop": "node ./node_modules/tsx/dist/cli.mjs tests/v5_interop.test.ts",
        "test:all": "npm run test && npm run typecheck",
        "lint": "eslint src/",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit"
    },
    "dependencies": {
        "msgpackr": "^1.11.9",
        "proper-lockfile": "^4.1.2",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/ws": "^8.18.1",
        "@types/proper-lockfile": "^4.1.4",
        "eslint": "^10.1.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2"
    }
}
